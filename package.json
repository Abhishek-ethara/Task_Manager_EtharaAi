{
  "name": "task-track",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",

    "build": "cd server && npm run build && cd ../client && npm run build",

    "start": "node server/dist/index.js"
  }
}